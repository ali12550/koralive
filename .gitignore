# Git Ignore Rules for Kora Live

# Environment variables
.env
.env.local
.env*.local
config.local.js
api-key.txt

# IDE/Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Node modules (if using Node.js for development)
node_modules/
package-lock.json
yarn.lock

# Build outputs
dist/
build/
.cache/

# OS files
.DS_Store
.env.production
.env.development

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
*.tmp
*.bak
*backup*
temp/

# Testing
coverage/
.nyc_output/

# Production
*.tar.gz
*.zip
archive/

# API keys and secrets
secrets.json
credentials.json
.credentials
